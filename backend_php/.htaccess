# ===========================================
# .htaccess cho ThoiKhoaBieu App Backend PHP
# ===========================================

# Disable directory listing
Options -Indexes

# Bật rewrite engine
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ===========================================
# CORS & Headers
# ===========================================
<IfModule mod_headers.c>
  Header always set Access-Control-Allow-Origin "*"
  Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-App-Key"
  Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Handle OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=204,L]

# ===========================================
# Protect sensitive files (comment install.php nếu cài lần đầu)
# ===========================================
<FilesMatch "^(config\.php|config\.example\.php|database\.php|\.env)$">
  Require all denied
</FilesMatch>

# Nếu muốn chạy install.php lần đầu, comment dòng sau
# <FilesMatch "install\.php$">
#   Require all denied
# </FilesMatch>

# Block backup/source files
<FilesMatch "\.(sql|bak|backup|log|ini|sh|md|env|yml|yaml|lock|txt)$">
  Require all denied
</FilesMatch>

# Prevent hidden files access
RedirectMatch 403 /\..*$

# ===========================================
# Disable PHP execution in uploads
# ===========================================
RewriteRule ^uploads/.*\.(php|phtml|php3|php4|php5|phar)$ - [F,L]

# ===========================================
# API specific rules
# ===========================================
RewriteRule ^share/?$ share.php [L,QSA]
RewriteRule ^share/([^/]+)/?$ share.php?id=$1 [L,QSA,B]

<Files "api.php">
  <IfModule mod_headers.c>
    Header set Content-Type "application/json; charset=utf-8"
    Header unset Content-Disposition
  </IfModule>
</Files>

# Block POST to api.php without app key
RewriteCond %{REQUEST_URI} ^/api\.php$
RewriteCond %{REQUEST_METHOD} POST
RewriteCond %{HTTP:X-App-Key} ^$
RewriteRule ^ - [F,L]

# ===========================================
# Upload limits
# ===========================================
php_value upload_max_filesize 20M
php_value post_max_size 25M
php_value max_execution_time 120
php_value max_input_time 120

# ===========================================
# Custom error responses
# ===========================================
ErrorDocument 403 "{\"success\":false,\"message\":\"Forbidden\"}"
ErrorDocument 404 "{\"success\":false,\"message\":\"Not found\"}"
ErrorDocument 500 "{\"success\":false,\"message\":\"Server error\"}"
